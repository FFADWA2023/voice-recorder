# ========================================
# API Keys and credentials
appsettings.Development.json
*.Development.json
.env
.env.local
.env.*.local
secrets.json
credential*
**/test_keys*
**/api_key*
**/*token*

# ========================================
# IDE & EDITOR (LOCAL DEV ONLY)
# ========================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
.DS_Store
Thumbs.db

# ========================================
# GIT & VERSION CONTROL
# ========================================
.git/
.gitmodules
*.orig

# ========================================
