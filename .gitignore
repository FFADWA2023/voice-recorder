CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.o
*.a
*.so
*.dylib

# C++ source code 

src/

# .NET build outputs (but KEEP project files for rebuilding)
bin/
obj/
*.dll
*.exe
*.pdb

# Node.js build outputs (but KEEP package.json for npm install)
node_modules/
dist/  # (for JS build output; bundled binaries in build_demo are kept)

